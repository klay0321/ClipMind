# ClipMind 环境变量示例 —— 复制为 .env 后按需修改。
# 注意：.env 已被 git 忽略，禁止把真实密钥/密码/NAS 凭据提交到仓库。

# ===== PostgreSQL =====
POSTGRES_USER=clipmind
POSTGRES_PASSWORD=clipmind
POSTGRES_DB=clipmind

# 应用连接串（API 使用 async 驱动；同步驱动由代码从此串自动派生用于 Alembic / worker）
DATABASE_URL=postgresql+asyncpg://clipmind:clipmind@postgres:5432/clipmind

# ===== Redis / Celery =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== 路径与安全（容器逻辑路径，必须位于白名单根之下）=====
# 允许配置为素材源的根目录白名单（逗号分隔），素材目录 mount_path 必须在其下
# 含只读 NAS 源 /app/source 与网页上传可写区 /app/uploads
ALLOWED_SOURCE_ROOTS=/app/source,/app/uploads
# 只读源目录在容器内的挂载点
SOURCE_MOUNT_PATH=/app/source
# 系统派生数据目录（可读写：数据库导出、缩略图、代理视频、片段、日志等）
DATA_DIR=/app/data
# 网页上传可写区（独立于只读 NAS 源；命名卷 clipmind-uploads）
UPLOAD_DIR=/app/uploads
# 单文件上传大小上限（MiB）
UPLOAD_MAX_MB=4096

# 宿主机上的只读源目录（compose 挂载用）。本地开发指向 sample_media。
# 生产部署时改为 NAS 原始素材目录，例如 /nas/video-assets
HOST_SOURCE_DIR=./sample_media

# ===== 服务端口（默认仅绑定 127.0.0.1，不对公网开放）=====
API_PORT=8000
WEB_PORT=3000

# ===== FFprobe / 扫描 =====
FFPROBE_TIMEOUT=30

# ===== PR-02 拆镜头 / 派生文件（media-worker）=====
# 单次 ffmpeg 调用超时（秒）；media-worker 并发（FFmpeg 重负载，默认 1）
FFMPEG_TIMEOUT=300
MEDIA_WORKER_CONCURRENCY=1
# 写派生文件前要求 data_dir 至少剩余空间（MiB）
DISK_MIN_FREE_MB=500
# 镜头检测（可替换）：pyscenedetect（主，内容检测）| fixed（固定时长兜底）
SHOT_DETECTOR_TYPE=pyscenedetect
SCENE_THRESHOLD=27.0
MIN_SHOT_DURATION=1.0
MAX_SHOT_DURATION=12.0
FALLBACK_SEGMENT_DURATION=5.0
HEAD_PADDING=0
TAIL_PADDING=0
# 代理视频 / 关键帧 / 缩略图
PROXY_MAX_HEIGHT=720
PROXY_CRF=28
PROXY_PRESET=veryfast
PROXY_KEEP_AUDIO=true
PROXY_AUDIO_BITRATE=96k
KEYFRAME_MAX_WIDTH=640
THUMBNAIL_MAX_WIDTH=320
# 关键帧条：沿镜头均匀采样的帧数（镜头详情多帧预览用）。0 表示仅主关键帧
AUX_KEYFRAMES=4

# ===== Web -> API（同源代理）=====
# 浏览器只访问同源 /api/*，由 web 容器服务端转发到内部 api。
# 该地址只在 Next.js 服务端使用，不会下发到浏览器。
API_INTERNAL_URL=http://api:8000
# 允许的前端来源（CORS / 同源校验）
WEB_ORIGIN=http://localhost:3000

# ===== 日志 =====
LOG_LEVEL=INFO

# ===== PR-03A AI 理解分析（ai-worker，ai 队列）=====
# AI_PROVIDER 留空 = 未配置（NotConfigured，绝不调用任何 API）；
#   fake = 确定性假 provider（测试/CI，不联网）；mimo = 小米 MiMo（OpenAI 兼容）。
# 真实密钥仅在本机 .env 提供，绝不提交仓库、绝不写入代码/日志/前端。
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_MAX_IMAGES=4
AI_TIMEOUT=60
AI_RETRIES=2
AI_PROMPT_VERSION=v1
AI_WORKER_CONCURRENCY=2
# 鉴权头：留空=Authorization: Bearer <key>；某些端点用自定义头如 api-key（类 Azure）
AI_API_KEY_HEADER=
# >0 时随请求发送 max_completion_tokens（0=不设）
AI_MAX_COMPLETION_TOKENS=0
# 计价（每 1K token；MiMo v2.5 约 $0.001/$0.003，按实价填；未知留 0 仅记 tokens）
AI_PRICE_INPUT_PER_1K=0
AI_PRICE_OUTPUT_PER_1K=0

# ===== PR-04 语义检索 / Embedding（search-worker，search 队列）=====
# MiMo 无 embedding 能力，故走独立 Embedding Provider：
#   ""=未配置（检索文档仅构建文本、不嵌入，索引标 degraded；搜索降级为词法/结构化）
#   fake=确定性假向量（CI/测试/降级验证，不联网、不下载模型）
#   openai_compatible=OpenAI 兼容 /embeddings（本地 embedder 微服务或外部端点）
EMBEDDING_PROVIDER=
# 指向本地 embedder（profile embedding 启用时）或外部端点；容器内用服务名 embedder
EMBEDDING_BASE_URL=http://embedder:8100
EMBEDDING_API_KEY=
EMBEDDING_MODEL=intfloat/multilingual-e5-small
# 默认即不可变 commit SHA（multilingual-e5-small 公开模型 revision，非敏感）。可覆盖；
# 若设为空/main/latest/head 且 EMBEDDING_REQUIRE_PINNED_REVISION=true（默认）→ fail-closed：
# 不嵌入、向量降级，但文档仍参与词法/pg_trgm/标签/产品检索（镜头不会完全无法被搜索）。换 revision 须全量重嵌。
EMBEDDING_MODEL_REVISION=614241f622f53c4eeff9890bdc4f31cfecc418b3
EMBEDDING_REQUIRE_PINNED_REVISION=true
# 必须与 vector 列维度一致（迁移 0007 为 vector(384)；换维度需新迁移）
EMBEDDING_DIMENSION=384
EMBEDDING_TIMEOUT=30
# e5（查询加 query: / 文档加 passage: 前缀）| none
EMBEDDING_PREFIX_SCHEME=e5
# search-worker 并发（纯 DB+HTTP，可适当并发）
SEARCH_WORKER_CONCURRENCY=2

# ---- Gate B 查询解析与混合检索（API 查询期）----
# 查询解析器：留空/auto = AI(mimo) 已配置则用 mimo 解析，否则规则解析；可显式 fake | rulebased | mimo
SEARCH_QUERY_PARSER=
# mimo 文本解析模型（留空默认 mimo-v2.5-pro，纯文本端点）
SEARCH_PARSER_MODEL=
# 解析超时（秒）：超时降级为规则解析，绝不阻断词法/结构化检索
SEARCH_PARSER_TIMEOUT=8
# 每召回通道候选池上限（有界融合；普通规模够用，过大影响首屏延迟）
SEARCH_CANDIDATE_POOL=200

# ---- 可选本地 embedder 微服务（profile "embedding"；torch + 多语模型，默认/CI 不启用）----
# 启用：docker compose --profile embedding up -d embedder
# 仅绑定 127.0.0.1:8100（不对公网开放）；容器间用服务名 embedder:8100。
EMBEDDER_PORT=8100
EMBEDDER_MODEL=intfloat/multilingual-e5-small
# 与 EMBEDDING_MODEL_REVISION 同一不可变 commit SHA（API/worker/embedder 须一致）
EMBEDDER_MODEL_REVISION=614241f622f53c4eeff9890bdc4f31cfecc418b3
EMBEDDER_DIMENSION=384
EMBEDDER_DEVICE=cpu

# ---- Docker 网络 ----
# 本项目 Compose 网络子网。默认 172.28.10.0/24，避开常见的 172.17(docker0)/172.19。
# 仅当内网 AI Provider 的私网 IP 落入默认段、或本机该段已被占用导致容器内 Provider
# 不可达（宿主机却可达，典型 No route to host）时才需覆盖为不冲突的私网 CIDR。
# 检测：python scripts/diagnose_ai_network.py --subnet <cidr> --show-ip
# 详见 docs/DOCKER_AI_NETWORKING.md。请填你本机不冲突的私网段，勿提交真实内网地址。
CLIPMIND_DOCKER_SUBNET=172.28.10.0/24

# 容器代理透传（仅当企业网络要求经代理访问外网 Provider 时设置；只透传变量、勿写凭据到仓库）。
# 内部服务名 postgres/redis 等已默认走直连；如设代理务必把它们加入 NO_PROXY。
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1,postgres,redis,api,web,worker,media-worker,ai-worker,search-worker,embedder
