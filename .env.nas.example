# ClipMind NAS 生产部署环境变量示例 —— 复制为 .env 后按需修改。
# 配合 docker-compose.nas.yml 使用。.env 已被 git 忽略，**绝不**提交真实密钥/密码/NAS 凭据。
# 详见 docs/NAS_DEPLOYMENT.md（部署人员）与 docs/BOSS_QUICKSTART.md（老板快速上手）。

# ============================================================
# NAS 部署关键路径 / 绑定（必须按你的 NAS 实际情况修改）
# ============================================================
# 持久化数据根目录（postgres/redis/派生数据/上传/模型/备份 全部落于此；请指向大容量磁盘）。
# 不要硬编码厂商专属路径——按你的 NAS 实际可写大盘路径填写，例如 /share/clipmind 或 /mnt/data/clipmind。
CLIPMIND_DATA_ROOT=./clipmind-data
# NAS 原始素材目录（只读挂载到 /app/source，系统绝不写入/改名/删除）。例如 /share/video-assets。
CLIPMIND_SOURCE_DIR=/please/set/your/nas/media/dir
# 端口绑定地址：默认仅本机 127.0.0.1。要让内网访问，设为 NAS 内网网卡 IP（如 192.168.1.10）
# 或 0.0.0.0（仅在已置于可信内网/VPN 或反向代理之后时）。**无应用级鉴权，切勿裸露公网。**
CLIPMIND_BIND_ADDR=127.0.0.1
# 服务端口
API_PORT=8000
WEB_PORT=3000

# ============================================================
# PostgreSQL（请把密码改成强口令；DATABASE_URL 必须与之一致）
# ============================================================
POSTGRES_USER=clipmind
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=clipmind
DATABASE_URL=postgresql+asyncpg://clipmind:CHANGE_ME_TO_A_STRONG_PASSWORD@postgres:5432/clipmind

# ===== Redis / Celery（容器内服务名互访）=====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== 容器内逻辑路径 / 安全白名单（一般无需改）=====
ALLOWED_SOURCE_ROOTS=/app/source,/app/uploads
SOURCE_MOUNT_PATH=/app/source
DATA_DIR=/app/data
UPLOAD_DIR=/app/uploads
UPLOAD_MAX_MB=4096

# ===== Web -> API 同源代理 / CORS =====
API_INTERNAL_URL=http://api:8000
# 前端来源：设为用户实际访问 Web 的地址（如 http://192.168.1.10:3000）
WEB_ORIGIN=http://localhost:3000

# ===== 日志 =====
LOG_LEVEL=INFO

# ===== 拆镜头 / 派生（media-worker）=====
FFPROBE_TIMEOUT=30
FFMPEG_TIMEOUT=300
MEDIA_WORKER_CONCURRENCY=1
DISK_MIN_FREE_MB=1000
SHOT_DETECTOR_TYPE=pyscenedetect
SCENE_THRESHOLD=27.0
MIN_SHOT_DURATION=1.0
MAX_SHOT_DURATION=12.0
FALLBACK_SEGMENT_DURATION=5.0
HEAD_PADDING=0
TAIL_PADDING=0
PROXY_MAX_HEIGHT=720
PROXY_CRF=28
PROXY_PRESET=veryfast
PROXY_KEEP_AUDIO=true
PROXY_AUDIO_BITRATE=96k
KEYFRAME_MAX_WIDTH=640
THUMBNAIL_MAX_WIDTH=320
AUX_KEYFRAMES=4

# ============================================================
# AI 理解（ai-worker）—— 真实视频打标需要外部 AI Provider（如小米 MiMo，OpenAI 兼容）
# 留空 = 不调用任何 AI（仅拆镜头/派生/检索可用，不产出 AI 描述/标签）。真实密钥仅在此 .env 提供。
# ============================================================
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_API_KEY_HEADER=
AI_MAX_IMAGES=4
AI_TIMEOUT=60
AI_RETRIES=2
AI_PROMPT_VERSION=v1
AI_WORKER_CONCURRENCY=2
AI_MAX_COMPLETION_TOKENS=0
AI_PRICE_INPUT_PER_1K=0
AI_PRICE_OUTPUT_PER_1K=0

# ============================================================
# 语义检索 / Embedding —— 默认启用内置 embedder（真实多语义检索）
# ============================================================
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=http://embedder:8100
EMBEDDING_API_KEY=
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_MODEL_REVISION=614241f622f53c4eeff9890bdc4f31cfecc418b3
EMBEDDING_REQUIRE_PINNED_REVISION=true
EMBEDDING_DIMENSION=384
EMBEDDING_TIMEOUT=30
EMBEDDING_PREFIX_SCHEME=e5
SEARCH_WORKER_CONCURRENCY=2
SEARCH_QUERY_PARSER=
SEARCH_PARSER_MODEL=
SEARCH_PARSER_TIMEOUT=8
SEARCH_CANDIDATE_POOL=200

# ===== 脚本拆段 / 匹配 / 导出 =====
SCRIPT_PARSER=
SCRIPT_PARSER_MODEL=
SCRIPT_PARSER_TIMEOUT=12
SCRIPT_MATCH_CANDIDATE_LIMIT=10
SCRIPT_MATCH_MIN_SCORE=0.05
SCRIPT_MATCH_MAX_REUSE=1
EXPORT_WORKER_CONCURRENCY=1

# ===== 内置 embedder 微服务 =====
EMBEDDER_MODEL=intfloat/multilingual-e5-small
EMBEDDER_MODEL_REVISION=614241f622f53c4eeff9890bdc4f31cfecc418b3
EMBEDDER_DIMENSION=384
EMBEDDER_DEVICE=cpu

# ===== Docker 网络子网（与内网 AI Provider 私网段冲突时才需改）=====
CLIPMIND_DOCKER_SUBNET=172.28.10.0/24
