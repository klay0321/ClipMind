# ===== Original media must NEVER be committed =====
# sample_media 仅作本地只读源目录，禁止提交任何视频
sample_media/**
!sample_media/
!sample_media/.gitkeep

# 本地 Gate C UI E2E 的合成视频源（禁止提交视频）
.e2e-src/
# Playwright E2E 本地产物
e2e/node_modules/
e2e/.artifacts*/
e2e/playwright-report/
e2e/test-results/

# ===== 本地真实素材验收（绝不提交：真实视频/关键帧/分析结果/DB dump/报告）=====
# 真实业务验收证据仅本地保存，详见 docs（PR-05 起的长期验收制度）
.local/

# E2E 本地状态文件（check-persist 用，不提交）
.pr*_e2e_state.json
.pma_e2e_state.json
.pops_e2e_state.json
*.webp
*.mp4
*.mov

# ===== 交付包构建产物（NAS 自包含交付包，由 scripts/nas/package.sh 生成，绝不提交）=====
dist/

# ===== 老板私密交付包 / 私密配置（含真实口令密钥，绝不提交；纵深防御，即使移出 dist 也忽略）=====
clipmind-boss-delivery*
*.private.env
*private-config*

