# ClipMind 环境变量示例 —— 复制为 .env 后按需修改。
# 注意：.env 已被 git 忽略，禁止把真实密钥/密码/NAS 凭据提交到仓库。

# ===== PostgreSQL =====
POSTGRES_USER=clipmind
POSTGRES_PASSWORD=clipmind
POSTGRES_DB=clipmind

# 应用连接串（API 使用 async 驱动；同步驱动由代码从此串自动派生用于 Alembic / worker）
DATABASE_URL=postgresql+asyncpg://clipmind:clipmind@postgres:5432/clipmind

# ===== Redis / Celery =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== 路径与安全（容器逻辑路径，必须位于白名单根之下）=====
# 允许配置为素材源的根目录白名单（逗号分隔），素材目录 mount_path 必须在其下
ALLOWED_SOURCE_ROOTS=/app/source
# 只读源目录在容器内的挂载点
SOURCE_MOUNT_PATH=/app/source
# 系统派生数据目录（可读写：数据库导出、缩略图、代理视频、片段、日志等）
DATA_DIR=/app/data

# 宿主机上的只读源目录（compose 挂载用）。本地开发指向 sample_media。
# 生产部署时改为 NAS 原始素材目录，例如 /nas/video-assets
HOST_SOURCE_DIR=./sample_media

# ===== 服务端口（默认仅绑定 127.0.0.1，不对公网开放）=====
API_PORT=8000
WEB_PORT=3000

# ===== FFprobe / 扫描 =====
FFPROBE_TIMEOUT=30

# ===== Web -> API（同源代理）=====
# 浏览器只访问同源 /api/*，由 web 容器服务端转发到内部 api。
# 该地址只在 Next.js 服务端使用，不会下发到浏览器。
API_INTERNAL_URL=http://api:8000
# 允许的前端来源（CORS / 同源校验）
WEB_ORIGIN=http://localhost:3000

# ===== 日志 =====
LOG_LEVEL=INFO

# =====================================================================
# 以下为后续 PR（PR-03 AI 理解）预留，PR-01 不使用、不调用、不要填真实值
# =====================================================================
# AI_PROVIDER=mimo
# AI_BASE_URL=
# AI_API_KEY=
# AI_MODEL=
# AI_MAX_IMAGES=4
